# Copia este archivo como .env y completa los valores

# === DESTINO DEL CORREO ===
# Email que recibirá los mensajes del formulario de contacto
CONTACT_EMAIL=desarrollo.corpoagro@gmail.com

# === CONFIGURACIÓN SMTP (Gmail como ejemplo) ===
# Para Gmail: Crea una "App Password" en tu cuenta de Google:
# 1. Activa 2FA en https://myaccount.google.com/security
# 2. Ve a "App Passwords": https://myaccount.google.com/apppasswords
# 3. Genera una para "Mail" y úsala como SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_PORT alternativo: 465 (SSL). En ese caso, pon SMTP_SECURE=true
SMTP_SECURE=false
SMTP_USER=desarrollo.corpoagro@gmail.com
SMTP_PASS=rgfr uekd zogj elap
#tu_app_password_aqui

